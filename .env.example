# 可选。留空时应用仍可使用内置 Mock Provider 完整运行。
OPENAI_API_KEY=

# 可选。默认使用 GPT Image 2 的稳定别名。
OPENAI_IMAGE_MODEL=gpt-image-2

# 可选。本地 ComfyUI 地址；地址只由服务端读取，不接受浏览器动态传入。
COMFYUI_BASE_URL=http://127.0.0.1:8188

# 可选。相对于项目根目录的 Provider 配置文件。
COMFYUI_CONFIG_PATH=config/comfyui-provider.json

# 可选。默认端口为 4173。
PORT=4173
