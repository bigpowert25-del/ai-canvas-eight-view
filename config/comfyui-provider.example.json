      "positivePrompt": ["6.inputs.text"],
      "negativePrompt": ["7.inputs.text"],
      "referenceImage": ["10.inputs.image"],
      "contextImage": ["11.inputs.image"],
      "seed": ["3.inputs.seed"],
      "steps": ["3.inputs.steps"],
      "width": ["5.inputs.width"],
